<?xml version="1.0" encoding="utf-8"?><!--
   Sample data extraction rules file; uncomment and customize as necessary.
   See https://developer.android.com/about/versions/12/backup-restore#xml-changes
   for details.
-->
<data-extraction-rules>
    <!-- Excluded: the "settings" DataStore holds the AES-GCM-encrypted API keys.
         The Android Keystore key that encrypts them never migrates across devices/
         reinstalls, so a restored ciphertext can never be decrypted again - excluding
         it here means a restore just leaves the API key fields empty instead of broken. -->
    <cloud-backup>
        <exclude domain="file" path="datastore/settings.preferences_pb"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="datastore/settings.preferences_pb"/>
    </device-transfer>
</data-extraction-rules>